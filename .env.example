# PostgreSQL
POSTGRES_USER=dinette
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=dinette

# This file goes at the project root as `.env` and is read by docker compose.

# Backend
DATABASE_URL=postgresql://dinette:changeme_strong_password@db:5432/dinette
JWT_SECRET=changeme_very_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=24h
PORT=3001
NODE_ENV=production
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
FRONTEND_URL=https://dinette.example.com

# Comma-separated URLs allowed by CORS. Keep frontend public URL here.
CORS_ORIGINS=https://dinette.example.com

# WebAuthn / Face ID / passkeys
# RP ID is usually the domain without protocol.
WEBAUTHN_RP_ID=dinette.example.com
WEBAUTHN_ORIGINS=https://dinette.example.com

# Demo seed behavior
# Recommended in production: false / false
SEED_TEST_USER=false
SEED_DEMO_RECIPES=false
SEED_USER_EMAIL=chef@dinette.app
SEED_USER_PASSWORD=change_me_demo_password
SEED_USER_NAME=Chef Marie

# Frontend (Vite build-time) — vide = utilise /api relatif
VITE_API_URL=

# External APIs
# Spoonacular (https://spoonacular.com/food-api) — free tier: 150 req/day
# Leave empty to disable Spoonacular integration
SPOONACULAR_API_KEY= 9806eb75f6fe4cef950a990969403fc7
