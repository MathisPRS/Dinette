{
  "name": "dinette-backend",
  "version": "1.0.0",
  "description": "Dinette API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
